# Browser-visible API base (Laravel). Leave empty to use same-origin Next.js
# routes under `app/api/*` (empty list until Laravel is connected).
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
API_INTERNAL_URL=http://127.0.0.1:3001

# Google Maps JavaScript API (map module). Enable "Maps JavaScript API" and
# "Geocoding API" for the same project / key restrictions as you use in prod.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
